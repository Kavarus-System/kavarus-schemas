{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/Kavarus-System/kavarus-schemas/refs/heads/main/schemas/triggers/onskill.schema.json",
    "type": "object",
    "properties": {
        "checkstat": {
            "enum": ["strength","intelligence","dexterity","intimidation","perception"]
        },
        "target": {
            "enum": [
                "any",
                "$parent",
                "self",
                "type.party",
                "type.enemy",
                "type.ally",
                "environment",
                "object"
            ]
        },
        "action": {
            "enum": ["cleareffect","applyeffect","attack","move","cast","hide","any"]
        }
    },
    "dependentRequired": {
        "action": ["target"]
    },
    "minProperties": 1
}
