{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/Kavarus-System/kavarus-schemas/refs/heads/main/schemas/triggers/random.schema.json",
    "type": "object",
    "properties": {
        "group": {
            "type": "string"
        },
        "odds": {
            "exclusiveMinimum": 0,
            "default": 1
        }
    },
    "if": {
        "required": ["group"]
    },
    "then": {
        "properties": {
            "odds": {
                "type": "integer"
            }
        }
    },
    "else": {
        "properties": {
            "odds": {
                "type": "number",
                "maximum": 1
            }
        }
    },
    "required": ["odds"]
}
